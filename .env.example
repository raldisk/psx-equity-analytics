# P3 — PSX Market Microstructure Analytics
# Copy to .env and fill in values before deployment. NEVER commit .env.

# ── DuckDB data root ──────────────────────────────────────────────────────────
# Absolute path to the directory containing data/, raw/, manifest.json
PSX_DATA_ROOT=/opt/airflow/data

# ── DuckDB file path (derived from PSX_DATA_ROOT) ────────────────────────────
# Resolved at runtime: ${PSX_DATA_ROOT}/psx_analytics.duckdb
# Do not set this separately; PSX_DATA_ROOT is the canonical anchor.

# ── API serving constraints ───────────────────────────────────────────────────
PSX_MAX_DATE_RANGE_DAYS=90
PSX_API_HOST=0.0.0.0
PSX_API_PORT=8000

# ── Airflow (shared with P2 installation) ─────────────────────────────────────
# P3 reuses the P2 Airflow 2.8.0 environment; do not override AIRFLOW_HOME here.
# Set P3-specific Airflow Variables via Airflow UI or airflow variables import.
PSX_AIRFLOW_CONN_ID=psx_duckdb_default

# ── SARIMA (optional — pipeline degrades gracefully if statsmodels absent) ────
# Set to 1 to enable SARIMA computation; 0 to force SKIPPED_NO_STATSMODELS.
PSX_SARIMA_ENABLED=1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json      # json | text
